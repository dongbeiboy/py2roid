# ============================================================
# py2roid .gitignore
# Android Gradle 项目 + Python 工具 + 开发环境杂项
# ============================================================

# ---- Android / Gradle 构建产物 ----
android/.gradle/
android/.kotlin/
android/build/
android/app/build/
android/app/bin/
android/local.properties
android/*.iml
android/.idea/
*.apk
*.aab
*.ap_
*.dex
*.class
gen/
captures/
out/

# ---- 调试 / 崩溃日志 ----
*.log
*.hprof
*.crash

# ---- Gradle Wrapper（保留 wrapper jar + properties，忽略本地分发包） ----
# gradle-wrapper.properties 必须提交，它锁定 Gradle 版本供全组使用
# 分发包在 ~/.gradle/wrapper/dists/ 中由 gradlew 自动管理
android/gradle-*.zip

# ---- 签名文件（敏感，禁止提交） ----
android/app/release.keystore
android/keystore.properties

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.venv/
venv/

# ---- 模型转换中间产物 ----
*.npy
android/app/src/main/assets/models/*_tflite/

# ---- ONNX / TFLite 模型（assets/models/ 下已入库的除外） ----
*.onnx
*.tflite
*.pb
!android/app/src/main/assets/models/*.onnx
!android/app/src/main/assets/models/*.tflite

# ---- Eval 数据（图片集、评测输出） ----
tools/eval/coco_images/
tools/eval/output/
tools/eval/coco_val2017.zip

# ---- UI 布局预览（本地 Squircle IDE 导出，非源码） ----
ui.xml

# ---- IDE / 编辑器 ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- 操作系统杂项 ----
.DS_Store
Thumbs.db

# ---- 项目文档（非代码，不入库） ----
plan.md

# ---- 环境 / 凭据 ----
.env
*.local
pair_adb.bat

# ---- 截屏 / 录屏 ----
screen.png

# ---- vivo 开放平台工具 ----
.vivo/
