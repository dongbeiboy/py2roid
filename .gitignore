# ============================================================
# py2roid .gitignore
# Android Gradle 项目 + Python 工具 + 开发环境杂项
# ============================================================

# ---- Android / Gradle ----
android/.gradle/
android/.kotlin/
android/build/
android/app/build/
android/app/bin/
android/local.properties
android/*.iml
android/.idea/
*.apk
*.aab
*.ap_
*.dex
*.class
*.log
*.hprof
*.crash
gen/
captures/
out/

# ---- Gradle Wrapper (保留 wrapper jar + properties，忽略本地分发包) ----
# gradle-wrapper.properties 必须提交，它锁定 Gradle 版本供全组使用
# 分发包在 ~/.gradle/wrapper/dists/ 中由 gradlew 自动管理
android/gradle-*.zip

# ---- 签名文件（敏感，禁止提交） ----
android/app/release.keystore
android/keystore.properties

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.venv/
venv/

# ---- Eval 数据（图片集、评测输出） ----
tools/eval/coco_images/
tools/eval/output/

# ---- ONNX 模型（assets/models/ 下的模型文件直接入库） ----
*.onnx
!android/app/src/main/assets/models/*.onnx

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- 项目文档（非代码，不入库） ----
plan.md

# ---- 环境 / 凭据 ----
.env
*.local
pair_adb.bat

# ---- vivo 开放平台工具 ----
.vivo/
tools/eval/coco_val2017.zip
screen.png
