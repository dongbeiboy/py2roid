{
  "description": "py2roid 推理后端 + 系统监控自动配置",
  "version": 2,
  "rules": [
    {
      "match": { "manufacturer": "vivo", "model": "iPA2475" },
      "backend": "VCAP",
      "system": {
        "thermal_base": "/sys/devices/virtual/thermal",
        "cpu_temp_zones": ["soc_max", "soc-bot1", "cpu-big-core7-0"],
        "gpu_temp_zones": ["gpu1"],
        "gpu_util_available": false,
        "num_cpu_cores": 8
      },
      "reason": "vivo 自研 VCAP 推理加速，绕过 NNAPI 兼容性问题"
    },
    {
      "match": { "manufacturer": "vivo" },
      "backend": "VCAP",
      "system": {
        "thermal_base": "/sys/devices/virtual/thermal",
        "cpu_temp_zones": ["soc_max"],
        "gpu_util_available": false
      },
      "reason": "vivo 自研 VCAP 推理加速，比 NNAPI 兼容性更好"
    },
    {
      "match": { "manufacturer": "xiaomi" },
      "backend": "NNAPI",
      "system": {
        "gpu_util_available": true
      },
      "reason": "骁龙 8 系 NNAPI 兼容性良好"
    },
    {
      "match": { "manufacturer": "OnePlus" },
      "backend": "NNAPI",
      "system": {
        "gpu_util_available": true
      },
      "reason": "骁龙 NNAPI 兼容"
    },
    {
      "match": { "manufacturer": "samsung" },
      "backend": "NNAPI",
      "system": {
        "gpu_util_available": true
      },
      "reason": "Exynos/骁龙 NNAPI 支持良好"
    },
    {
      "match": { "manufacturer": "google" },
      "backend": "NNAPI",
      "system": {
        "gpu_util_available": true
      },
      "reason": "Pixel Tensor NNAPI 支持"
    },
    {
      "match": { "manufacturer": "HUAWEI" },
      "backend": "CPU",
      "system": {
        "gpu_util_available": false
      },
      "reason": "麒麟 NPU 需通过 HiAI，NNAPI 不可靠"
    },
    {
      "match": { "manufacturer": "honor" },
      "backend": "CPU",
      "system": {
        "gpu_util_available": false
      },
      "reason": "同华为，NNAPI 兼容性差"
    }
  ],
  "default": "NNAPI"
}
